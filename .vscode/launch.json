{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": ["--config=${workspaceFolder}/myconfig.conf", "--dev=all"],
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
     
    },

